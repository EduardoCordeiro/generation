# Create a Spotify app and add http://127.0.0.1:3000/api/auth/spotify/callback as its redirect URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback

# Obtain an API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Enable the YouTube Data API v3 and register this OAuth callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/auth/youtube/callback

# Use a long random value to encrypt provider refresh tokens.
SESSION_SECRET=
